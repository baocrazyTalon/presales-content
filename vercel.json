{
  "framework": null,
  "installCommand": "npm install",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/my-muscle-chef", "destination": "/CLIENTS/OPPORTUNITIES/MY%20MUSCLE%20CHEF/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
