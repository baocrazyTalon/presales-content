{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": ".vercel/output",
    "rootDir": ".",
    "lib": ["ES2020", "DOM"],
    "types": ["node"]
  },
  "include": ["api/**/*.ts", "middleware.ts"],
  "exclude": ["node_modules"]
}
