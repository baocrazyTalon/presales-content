# ─────────────────────────────────────────────────────────────
# Talon.One Presales Agent — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# ── LLM Provider: Gemini (Google AI Studio) ──────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# LLM model
LLM_MODEL=gemini-2.5-pro

# ── PostgreSQL / pgvector ─────────────────────────────────────
POSTGRES_USER=presales
POSTGRES_PASSWORD=presales_secret
POSTGRES_DB=presales_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Full DSN (auto-constructed from above if left blank)
DATABASE_URL=postgresql+psycopg://presales:presales_secret@localhost:5433/presales_db

# ── Notion ───────────────────────────────────────────────────
# Internal Integration token — https://www.notion.so/my-integrations
# Share the relevant pages/databases with the integration inside Notion.
NOTION_API_KEY=secret_...
# Max pages fetched per Notion search (keep low to limit latency)
NOTION_MAX_PAGES=5

# ── Google Drive ──────────────────────────────────────────────
# Path to your OAuth 2.0 credentials JSON downloaded from GCP
GOOGLE_CREDENTIALS_PATH=./credentials/google_credentials.json
# Shared Drive or folder ID to index
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ── GitHub ────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/presales-content       # e.g. talon-one/presales-decks
GITHUB_DEFAULT_BRANCH=main

# ── Vercel ────────────────────────────────────────────────────
VERCEL_TOKEN=...
VERCEL_PROJECT_ID=...
VERCEL_TEAM_ID=                              # leave blank for personal accounts

# ── Agent Tuning ──────────────────────────────────────────────
# Max RAG chunks returned per query
RAG_TOP_K=8
# Max LangGraph iterations before aborting
MAX_ITERATIONS=10
# Embedding model — must match vector(3072) dimension in init.sql
EMBEDDING_MODEL=gemini-embedding-001
